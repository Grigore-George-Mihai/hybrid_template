<% content_for :title, "Home" %>

<section class="d-flex flex-column align-items-center justify-content-center text-center py-5 my-4">
  <h1 class="display-5 fw-bold mb-3">Everything included</h1>
  <p class="lead text-muted mb-0" style="max-width: 640px;">
    A Rails starter with auth, admin, background jobs, and a Grape API already wired up — ready for you to build on.
  </p>
</section>

<section class="pb-5">
  <div class="row g-4">
    <% [
      { icon: "fa-lock",       title: "Authentication", body: "Devise with JWT auth for the API, ready for email, password resets and registrations." },
      { icon: "fa-user-shield", title: "Admin Panel",   body: "ActiveAdmin pre-configured with role-based access, users resource, and batch actions." },
      { icon: "fa-bolt",        title: "Background Jobs", body: "Sidekiq with sidekiq-scheduler, split queues, and a mounted web UI for admins." },
      { icon: "fa-rocket",      title: "Hotwire",         body: "Turbo and Stimulus via importmap — no bundler, no build step, modern interactions." },
      { icon: "fa-database",    title: "PostgreSQL",      body: "PgHero dashboard, pg_stat_statements, and Bullet to catch N+1 queries in development." },
      { icon: "fa-box",         title: "Docker Ready",    body: "Dockerfile and scripts included so you can ship to any container platform out of the box." }
    ].each do |feature| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card feature-card h-100 border-0 shadow-sm">
          <div class="card-body p-4">
            <div class="feature-icon mb-3">
              <i class="fas <%= feature[:icon] %>"></i>
            </div>
            <h5 class="card-title fw-semibold mb-2"><%= feature[:title] %></h5>
            <p class="card-text text-muted mb-0"><%= feature[:body] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
