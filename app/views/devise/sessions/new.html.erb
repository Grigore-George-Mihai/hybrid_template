<% content_for :title, "Log in" %>

<div class="auth-wrapper">
  <div class="card auth-card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5">
      <h1 class="h3 fw-bold text-center mb-1">Welcome back</h1>
      <p class="text-muted text-center mb-4">Log in to continue to your account.</p>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name),
                          wrapper: :vertical_form, html: { class: "auth-form" }) do |f| %>
        <%= f.input :email, required: false, autofocus: true,
                    input_html: { autocomplete: "email", class: "form-control form-control-lg" } %>
        <%= f.input :password, required: false,
                    input_html: { autocomplete: "current-password", class: "form-control form-control-lg" } %>

        <% if devise_mapping.rememberable? %>
          <%= f.input :remember_me, as: :boolean, label: "Remember me",
                      wrapper_html: { class: "form-check mb-3" },
                      input_html: { class: "form-check-input" },
                      label_html: { class: "form-check-label" } %>
        <% end %>

        <%= f.button :submit, "Log in", class: "btn btn-accent btn-lg w-100" %>
      <% end %>

      <div class="auth-links text-center mt-4 small">
        <% if devise_mapping.registerable? %>
          <%= link_to "Sign up", new_registration_path(resource_name), class: "text-decoration-none me-3" %>
        <% end %>
        <% if devise_mapping.recoverable? %>
          <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-decoration-none" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
